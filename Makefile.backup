# ANSI 색상 코드 (TUI/터미널 가독성용)
BLUE   = \033[1;34m
GREEN  = \033[1;32m
YELLOW = \033[1;33m
RED    = \033[1;31m
RESET  = \033[0m

.PHONY: help infra-up infra-down ps scraper websocket all

help:
	@echo "$(BLUE)Stocat Asset Microservices 관리 도구$(RESET)"
	@echo "사용 가능한 명령:"
	@echo "  $(GREEN)infra-up$(RESET)        Docker Compose를 이용한 인프라(Redis, MySQL) 기동"
	@echo "  $(GREEN)infra-down$(RESET)      모든 인프라 컨테이너 종료 및 삭제"
	@echo "  $(GREEN)ps$(RESET)              실행 중인 컨테이너 상태 확인"
	@echo "  $(YELLOW)scraper$(RESET)         Asset Scraper 서비스 실행 (Gradle)"
	@echo "  $(YELLOW)websocket$(RESET)       Asset WebSocket API 서비스 실행 (Gradle)"
	@echo "  $(BLUE)all$(RESET)             인프라 기동 및 모든 서비스 실행"

# --- 1. Infrastructure (인프라 계층) ---
infra-up:
	@echo "$(BLUE)[infra] 인프라를 기동합니다...$(RESET)"
	docker-compose up -d

infra-down:
	@echo "$(RED)[infra] 모든 구성을 종료합니다...$(RESET)"
	docker-compose down

ps:
	@echo "$(BLUE)[infra] 컨테이너 상태:$(RESET)"
	@docker-compose ps

# --- 2. Applications (애플리케이션 계층) ---
scraper:
	@echo "$(YELLOW)[app] Asset Scraper 실행 중...$(RESET)"
	./gradlew :asset-scraper:bootRun

websocket:
	@echo "$(YELLOW)[app] Asset WebSocket API 실행 중...$(RESET)"
	./gradlew :asset-websocket-api:bootRun

# --- 3. Orchestration (복합 실행) ---
# 주의: bootRun은 블로킹 작업이므로 TUI 등에서는 별도 프로세스로 띄워야 함
all: infra-up
	@echo "$(GREEN)[all] 모든 서비스를 순차적으로 실행합니다...$(RESET)"
	@echo "$(YELLOW)참고: 로컬 터미널에서는 순차 실행 시 블로킹될 수 있습니다.$(RESET)"
	$(MAKE) scraper & $(MAKE) websocket
